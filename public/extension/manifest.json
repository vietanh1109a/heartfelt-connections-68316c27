{
  "manifest_version": 3,
  "name": "Netflix Cookie Manager",
  "version": "2.2.0",
  "description": "Tự động đăng nhập Netflix Premium từ website",
  "permissions": [
    "cookies",
    "tabs",
    "scripting",
    "storage",
    "offscreen",
    "activeTab"
  ],
  "action": {
    "default_title": "Netflix Cookie Manager"
  },
  "host_permissions": [
    "https://*.netflix.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "matches": [
      "*://*.lovable.app/*",
      "*://*.lovableproject.com/*",
      "http://localhost:*/*",
      "https://localhost:*/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
